# CodeQL CLI (optional: use if codeql is not on PATH)
# CODEQL_PATH=codeql

# OpenAI (optional for Phase 1; required for LLM verification in later phases)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Ollama (optional; use if running local or remote Ollama)
# OLLAMA_MODEL=ollama/llama3.2
# OLLAMA_API_BASE=http://localhost:11434
# For Ollama on another server, e.g.:
# OLLAMA_API_BASE=http://192.168.1.10:11434
# OLLAMA_API_BASE=https://ollama.example.com
