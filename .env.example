# CodeQL CLI (optional: use if codeql is not on PATH)
# CODEQL_PATH=codeql

# OpenAI (optional for Phase 1; required for LLM verification in Phase 4)
# OPENAI_API_KEY=sk-...

# Ollama (optional; use if running local or remote Ollama)
# OLLAMA_API_BASE=http://localhost:11434
# For Ollama on another server, e.g.:
# OLLAMA_API_BASE=http://192.168.1.10:11434
# OLLAMA_API_BASE=https://ollama.example.com

# Phase 4: LLM Provider Settings
# LLM_PROVIDER=openai          # openai or ollama
# LLM_MODEL=gpt-4o             # Model to use (e.g., gpt-4o, gpt-4o-mini, ollama/llama3.2, ollama/codellama)
