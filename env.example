# =============================================================================
# VulnHunterX - SAST + fuzzing + LLM vulnerability verification
# =============================================================================
# This file contains SECRETS and ENVIRONMENT-SPECIFIC settings.
# Application settings (mode, temperature, limits) go in config/confirm_findings.yaml
#
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys (SECRETS - never commit real values!)
# -----------------------------------------------------------------------------

# OpenAI API key (required for OpenAI provider)
# OPENAI_API_KEY=sk-...

# Custom OpenAI-compatible endpoint (optional; for Z.ai, Azure, or other OpenAI-compatible APIs)
# OPENAI_BASE_URL=https://api.example.com/v1
# OPENAI_API_BASE=https://api.example.com/v1

# -----------------------------------------------------------------------------
# Environment-Specific Settings
# -----------------------------------------------------------------------------

# LLM provider: openai or ollama (default: openai)
# LLM_PROVIDER=openai
# LLM_PROVIDER=ollama

# LLM model name (overrides config file)
# For OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# For Ollama: ollama/llama3.2, ollama/qwen3:latest, ollama/codellama
# LLM_MODEL=gpt-4o
# LLM_MODEL=ollama/llama3.2

# CodeQL CLI path (only needed if codeql is not on PATH)
# CODEQL_PATH=/path/to/codeql

# Semgrep CLI path (only needed if using Semgrep and semgrep is not on PATH)
# SEMGREP_PATH=/path/to/semgrep

# Ollama server URL (only needed for remote Ollama server)
# Default: http://localhost:11434
# OLLAMA_API_BASE=http://localhost:11434
# OLLAMA_API_BASE=http://192.168.1.10:11434
# OLLAMA_API_BASE=https://ollama.example.com
