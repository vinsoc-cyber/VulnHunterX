# VulnHunterX Environment Configuration
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# =============================================================================
# LLM Provider Selection
# =============================================================================

# Provider: openai | ollama | anthropic
LLM_PROVIDER=openai

# Model name (must match the provider):
#   OpenAI:    gpt-4o, gpt-4o-mini, gpt-4-turbo
#   Anthropic: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
#   Ollama:    ollama/llama3.2, ollama/qwen3:latest, ollama/codellama
LLM_MODEL=gpt-4o

# =============================================================================
# OpenAI (and OpenAI-compatible endpoints)
# =============================================================================

OPENAI_API_KEY=your_openai_api_key_here

# Optional: custom base URL for OpenAI-compatible services (e.g. Azure, Z.ai)
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Anthropic (Claude)
# =============================================================================

# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# Ollama (local or remote open-source models)
# =============================================================================

# OLLAMA_API_BASE=http://localhost:11434

# =============================================================================
# Tool Paths (if not on PATH)
# =============================================================================

# CODEQL_PATH=/path/to/codeql
# SEMGREP_PATH=/path/to/semgrep
