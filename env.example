# =============================================================================
# Environment Variables for CodeQL + LLM Framework
# =============================================================================
# This file contains SECRETS and ENVIRONMENT-SPECIFIC settings.
# Application settings (mode, temperature, limits) go in config/confirm_findings.yaml
#
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys (SECRETS - never commit real values!)
# -----------------------------------------------------------------------------

# OpenAI API key (required for OpenAI provider)
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Environment-Specific Settings
# -----------------------------------------------------------------------------

# CodeQL CLI path (only needed if codeql is not on PATH)
# CODEQL_PATH=/path/to/codeql

# Ollama server URL (only needed for remote Ollama server)
# Default: http://localhost:11434
# OLLAMA_API_BASE=http://localhost:11434
# OLLAMA_API_BASE=http://192.168.1.10:11434
# OLLAMA_API_BASE=https://ollama.example.com
