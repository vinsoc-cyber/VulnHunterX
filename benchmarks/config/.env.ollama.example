# VulnHunterX — Ollama Cloud credentials (model-matrix template)
# Copy to a repo-root `.env.ollama` and fill in real values.
LLM_PROVIDER=ollama

LLM_MODEL=qwen3-coder:480b-cloud

# Ollama Cloud bearer pool — comma-separated list of keys (a single key also
# works). NOTE: Ollama Cloud uses OLLAMA_API_KEYS (plural); OLLAMA_API_KEY
# (singular) is not accepted.
OLLAMA_API_KEYS=REPLACE_ME_KEY1,REPLACE_ME_KEY2

OLLAMA_API_BASE=https://ollama.com
