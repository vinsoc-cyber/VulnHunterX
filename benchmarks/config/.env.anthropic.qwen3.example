# VulnHunterX — Anthropic-compatible proxy (Qwen via MaaS) template
# Copy to a repo-root `.env.anthropic.qwen3` and fill in real values.
LLM_PROVIDER=anthropic
LLM_MODEL=qwen3.6-plus

# Anthropic-compatible API key + base URL for the proxy.
ANTHROPIC_API_KEY=sk-REPLACE_ME
ANTHROPIC_API_BASE=https://your-anthropic-compatible-endpoint/apps/anthropic

# Map every Anthropic model alias to the served model.
ANTHROPIC_MODEL=qwen3.6-plus
ANTHROPIC_SMALL_FAST_MODEL=qwen3.6-plus
ANTHROPIC_DEFAULT_HAIKU_MODEL=qwen3.6-plus
ANTHROPIC_DEFAULT_SONNET_MODEL=qwen3.6-plus
ANTHROPIC_DEFAULT_OPUS_MODEL=qwen3.6-plus
CLAUDE_CODE_SUBAGENT_MODEL=qwen3.6-plus
