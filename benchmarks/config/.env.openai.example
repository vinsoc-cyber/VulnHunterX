# VulnHunterX — OpenAI credentials (model-matrix template)
# Copy to a repo-root `.env.openai` and fill in real values. Never commit the
# filled-in copy (repo-root `.env.*` is gitignored).

# Provider: openai | ollama | anthropic
LLM_PROVIDER=openai

# Model id passed to --model (LLMClient adds provider prefixes).
LLM_MODEL=gpt-4.1-mini

# OpenAI API key (https://platform.openai.com/api-keys).
OPENAI_API_KEY=sk-REPLACE_ME
