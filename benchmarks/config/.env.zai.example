# VulnHunterX — Z.AI / GLM (Anthropic-compatible proxy) template
# Copy to a repo-root `.env.zai` and fill in real values.
LLM_PROVIDER=anthropic

LLM_MODEL=glm/glm-5.1

# Anthropic-compatible API key + base URL for the proxy.
ANTHROPIC_API_KEY=sk-REPLACE_ME
ANTHROPIC_BASE_URL=https://your-anthropic-compatible-endpoint/v1
