# VulnHunterX — DeepSeek credentials (model-matrix template)
# Copy to a repo-root `.env.deepseek` and fill in real values.
#
# DeepSeek is OpenAI-compatible: keep provider=openai and point OPENAI_BASE_URL
# at the DeepSeek endpoint. LLMClient adds the required `openai/` model prefix.
LLM_PROVIDER=openai

# DeepSeek V4 models (1M context, dual-mode):
#   deepseek-v4-flash — cheap tier
#   deepseek-v4-pro   — frontier tier
# Legacy V3 ids deepseek-chat / deepseek-reasoner still resolve.
LLM_MODEL=deepseek-v4-flash
# LLM_MODEL=deepseek-v4-pro

# DeepSeek API key (https://platform.deepseek.com/api_keys).
OPENAI_API_KEY=sk-REPLACE_ME

# OpenAI-compatible base URL for DeepSeek.
OPENAI_BASE_URL=https://api.deepseek.com/
