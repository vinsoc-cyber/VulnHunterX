# VulnHunterX — Alibaba DashScope (Qwen, OpenAI-compatible) template
# Copy to a repo-root `.env.alibaba` and fill in real values.
LLM_PROVIDER=openai

LLM_MODEL=qwen3-coder-480b-a35b-instruct

# DashScope API key.
OPENAI_API_KEY=sk-REPLACE_ME

# OpenAI-compatible base URL for DashScope (international endpoint).
OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
