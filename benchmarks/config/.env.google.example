# VulnHunterX — OpenAI-compatible endpoint template
# Copy to a repo-root `.env.google` and fill in real values.
LLM_PROVIDER=openai

LLM_MODEL=deepseek-v4-flash

# API key for the OpenAI-compatible endpoint below.
OPENAI_API_KEY=sk-REPLACE_ME

# OpenAI-compatible base URL.
OPENAI_BASE_URL=https://api.deepseek.com/
